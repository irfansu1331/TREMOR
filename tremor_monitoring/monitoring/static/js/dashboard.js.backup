// Global State Management
const state = {
    currentData: [],
    hourlyData: {},
    notifications: [],
    locations: [
        { id: 1, name: "Ruangan Monitoring", description: "Ruangan Monitoring Utama", status: "online", lastUpdate: Date.now() }
    ],
    thresholds: {
        temperature: { warning_low: 15, warning_high: 30, danger_low: 10, danger_high: 35 },
        humidity: { warning_low: 30, warning_high: 75, danger_low: 20, danger_high: 85 }
    },
    theme: 'light',
    mqttConnected: false,
    apiConnected: false,
    lastSensorUpdate: Date.now(),
    sensorTimeout: 45000  // 45 seconds - consider inactive if no data received
};

// Charts storage
let charts = {
    realtime: null,
    trend: null
};

// ============================================
// INITIALIZATION
// ============================================

// Update realtime clock display
function updateClock() {
    const now = new Date();
    
    // Format time HH:MM:SS
    const hours = String(now.getHours()).padStart(2, '0');
    const minutes = String(now.getMinutes()).padStart(2, '0');
    const seconds = String(now.getSeconds()).padStart(2, '0');
    
    // Format date DD-MonthName-YYYY (Indonesian month names)
    const monthNames = ['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 
                        'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember'];
    const date = String(now.getDate()).padStart(2, '0');
    const month = monthNames[now.getMonth()];
    const year = now.getFullYear();
    
    const clockDisplay = document.getElementById('clockDisplay');
    const dateDisplay = document.getElementById('dateDisplay');
    
    if (clockDisplay) {
        clockDisplay.textContent = `${hours}:${minutes}:${seconds}`;
    }
    if (dateDisplay) {
        dateDisplay.textContent = `${date}-${month}-${year}`;
    }
}

function initDashboard() {
    console.log('Initializing dashboard...');
    setupEventListeners();
    setupCharts();
    setupExportTypeButtons();
    loadThresholdSettings();
    updateLocationsList();
    updateDevicesStatus();
    
    // Request browser notification permission untuk anomaly alerts
    if ('Notification' in window && Notification.permission === 'default') {
        Notification.requestPermission();
    }
    
    // Start realtime clock
    updateClock();
    setInterval(updateClock, 1000);
    
    // Load initial history data (all data, max 50 rows)
    updateHistoryTableWithFilter('all');
    
    // Start polling for latest sensor data every 3 seconds
    console.log('Starting API polling...');
    pollSensorData();
    setInterval(pollSensorData, 3000);
    
    // Update history table every 5 seconds with current filter selection (preserve scroll position)
    setInterval(() => {
        const activeFilterBtn = document.querySelector('.data-filter .action-btn.active');
        if (activeFilterBtn) {
            const filterType = activeFilterBtn.getAttribute('data-filter-type');
            updateHistoryTableWithFilter(filterType);
        }
    }, 5000);
    
    // Check sensor connection status frequently (every 3 seconds)
    checkSensorConnectionStatus();
    setInterval(checkSensorConnectionStatus, 3000);
}

// ============================================
// EVENT LISTENERS SETUP
// ============================================

function setupEventListeners() {
    // Theme Toggle
    const themeToggle = document.getElementById('themeToggle');
    if (themeToggle) {
        themeToggle.addEventListener('click', toggleTheme);
    }
    
    // Menu Navigation
    document.querySelectorAll('.menu-item').forEach(item => {
        item.addEventListener('click', function() {
            const page = this.getAttribute('data-page');
            switchPage(page);
            
            if (window.innerWidth <= 1024) {
                document.getElementById('sidebar').classList.remove('active');
            }
        });
    });
    
    // Time Filter
    const timeFilterBtns = document.querySelectorAll('.time-filter .action-btn');
    console.log(`Found ${timeFilterBtns.length} time filter buttons`);
    
    // Data Filter (Semua Data / Danger Only)
    const dataFilterBtns = document.querySelectorAll('.data-filter .action-btn');
    console.log(`Found ${dataFilterBtns.length} data filter buttons`);
    
    dataFilterBtns.forEach(btn => {
        btn.addEventListener('click', function() {
            const filterType = this.getAttribute('data-filter-type');
            console.log(`Data filter button clicked: ${filterType}`);
            document.querySelectorAll('.data-filter .action-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            
            // Update table with filter
            updateHistoryTableWithFilter(filterType);
        });
    });
    
    // Mobile Menu Toggle
    const mobileMenuToggle = document.getElementById('mobileMenuToggle');
    if (mobileMenuToggle) {
        mobileMenuToggle.addEventListener('click', function() {
            document.getElementById('sidebar').classList.toggle('active');
        });
    }
    
    // Logout Button Handler
    const logoutBtn = document.getElementById('logoutBtn');
    if (logoutBtn) {
        logoutBtn.addEventListener('click', function() {
            if (confirm('Apakah Anda yakin ingin logout?')) {
                document.getElementById('logoutForm').submit();
            }
        });
    }
    
    // Close sidebar when clicking outside on mobile
    document.addEventListener('click', function(event) {
        const sidebar = document.getElementById('sidebar');
        const mobileToggle = document.getElementById('mobileMenuToggle');
        
        if (window.innerWidth <= 1024 && 
            !sidebar.contains(event.target) && 
            !mobileToggle.contains(event.target) &&
            sidebar.classList.contains('active')) {
            sidebar.classList.remove('active');
        }
    });
}

// ============================================
// SENSOR DATA HANDLING
// ============================================

// Poll sensor data from API every 3 seconds
function pollSensorData() {
    console.log('pollSensorData() calling /api/latest/');
    fetch('/api/latest/', { credentials: 'same-origin' })
        .then(response => {
            if (!response.ok) {
                throw new Error(`API error: ${response.status}`);
            }
            const contentType = response.headers.get('content-type') || '';
            if (!contentType.includes('application/json')) {
                throw new Error('API returned non-JSON response (session may have expired)');
            }
            return response.json();
        })
        .then(data => {
            console.log('API Response:', data);
            if (data && data.temperature !== undefined && data.humidity !== undefined) {
                // Map API response to sensor data format
                const sensorData = {
                    temperature: data.temperature,
                    humidity: data.humidity,
                    temp_status: data.temp_status,
                    humidity_status: data.humidity_status,
                    location: data.location,
                    timestamp: new Date(data.timestamp).getTime()
                };
                handleSensorData(sensorData);
                updateConnectionStatus('connected');
            }
        })
        .catch(error => {
            console.error('API polling error:', error);
            updateConnectionStatus('disconnected');
        });
}

// Update connection status indicator
function checkSensorConnectionStatus() {
    console.log('checkSensorConnectionStatus() calling /api/sensor-status/');
    fetch('/api/sensor-status/', { credentials: 'same-origin' })
        .then(response => {
            if (!response.ok) {
                throw new Error(`Sensor status error: ${response.status}`);
            }
            return response.json();
        })
        .then(data => {
            console.log('Sensor Status:', data);
            const isActive = data.is_connected === true;
            
            // Update system status based on sensor data freshness
            const systemStatusEl = document.getElementById('systemStatus');
            if (systemStatusEl) {
                if (isActive) {
                    systemStatusEl.innerHTML = '<i class="fas fa-circle" style="color: #10b981; font-size: 8px; margin-right: 6px;"></i>Aktif';
                    systemStatusEl.style.color = '#10b981';  // Green
                } else {
                    systemStatusEl.innerHTML = '<i class="fas fa-circle" style="color: #ef4444; font-size: 8px; margin-right: 6px;"></i>Tidak Aktif';
                    systemStatusEl.style.color = '#ef4444';  // Red
                }
            }
            
            // Update status dot
            const statusDot = document.getElementById('statusDot');
            if (statusDot) {
                statusDot.className = `status-dot ${isActive ? 'safe' : 'danger'}`;
            }
            
            // Console log untuk debug
            const seconds = data.seconds_since_last_reading ?? '?';
            console.log(`Sensor ${isActive ? 'active' : 'inactive'}: last reading ${seconds}s ago`);
        })
        .catch(error => {
            console.error('Sensor status check error:', error);
            // Mark as inactive if we can't reach the endpoint
            const systemStatusEl = document.getElementById('systemStatus');
            if (systemStatusEl) {
                systemStatusEl.innerHTML = '<i class="fas fa-circle" style="color: #ef4444; font-size: 8px; margin-right: 6px;"></i>Tidak Aktif';
                systemStatusEl.style.color = '#ef4444';
            }
        });
}

// Update connection status indicator
function updateConnectionStatus(status) {
    const statusIndicator = document.getElementById('statusIndicator');
    const statusText = document.getElementById('statusText');
    const statusDot = document.getElementById('statusDot');
    
    if (statusIndicator) {
        statusIndicator.textContent = status === 'connected' ? '✅ Connected' : '⚠️ Disconnected';
    }
    
    if (statusText) {
        statusText.textContent = status === 'connected' ? 'Connected' : 'Disconnected';
    }
    
    if (statusDot) {
        statusDot.className = `status-dot ${status}`;
    }
}

function handleSensorData(data) {
    console.log('Processing sensor data:', data);
    
    // Update last sensor update time
    state.lastSensorUpdate = Date.now();
    
    // Validate and extract temperature and humidity
    const temperature = parseFloat(data.temperature);
    const humidity = parseFloat(data.humidity);
    
    if (isNaN(temperature) || isNaN(humidity)) {
        console.error('Invalid sensor values:', data);
        return;
    }
    
    // Create reading object
    const reading = {
        timestamp: data.timestamp || Date.now(),
        temperature: parseFloat(temperature.toFixed(2)),
        humidity: parseFloat(humidity.toFixed(2)),
        temp_status: data.temp_status || getTemperatureStatus(temperature),
        humidity_status: data.humidity_status || getHumidityStatus(humidity),
        location: data.location || 'Ruangan Monitoring',
        source: data.source || 'MQTT'
    };
    
    // Add to data array (keep last 200 readings)
    state.currentData.push(reading);
    if (state.currentData.length > 200) {
        state.currentData.shift();
    }
    
    console.log(`New reading: Temp=${reading.temperature}°C (${reading.temp_status}), Humidity=${reading.humidity}% (${reading.humidity_status})`);
    
    // Check for threshold breach and add notification
    checkThresholdBreach(reading);
    
    // Update dashboard
    updateDashboard();
}

// Get temperature status
function getTemperatureStatus(temperature) {
    const t = state.thresholds.temperature;
    if (temperature <= t.danger_low || temperature >= t.danger_high) return 'danger';
    if (temperature < t.warning_low || temperature > t.warning_high) return 'warning';
    return 'normal';
}

// Get humidity status
function getHumidityStatus(humidity) {
    const h = state.thresholds.humidity;
    if (humidity <= h.danger_low || humidity >= h.danger_high) return 'danger';
    if (humidity < h.warning_low || humidity > h.warning_high) return 'warning';
    return 'normal';
}

// Get status based on value
function getStatus(value) {
    if (value >= state.thresholds.danger) return 'danger';
    if (value >= state.thresholds.warning) return 'warning';
    return 'safe';
}

// ============================================
// SYSTEM STATUS
// ============================================

// ============================================
// STATUS AND METRICS
// ============================================
// DASHBOARD UPDATES
// ============================================

function updateDashboard() {
    if (state.currentData.length === 0) return;
    console.log('updateDashboard(), latest=', state.currentData[state.currentData.length-1]);
    
    const latest = state.currentData[state.currentData.length - 1];
    const recentData = state.currentData.slice(-20);
    
    // Update current reading
    updateCurrentReading(latest);
    
    // Update statistics
    updateStatistics(recentData);
    
    // Update status indicator
    updateStatusIndicator(latest);
    
    // Update charts
    updateCharts();
    
    // Don't update history table on every poll - causes scroll reset
    // updateHistoryTable('3hours');
    
    // Update AI prediction
    updateAIPrediction();
}

function updateCurrentReading(latest) {
    // Current temperature
    const currentValueEl = document.getElementById('currentValue');
    if (currentValueEl) {
        currentValueEl.textContent = latest.temperature.toFixed(1);
    }
    
    // Current humidity
    const currentHumidityEl = document.getElementById('currentHumidity');
    if (currentHumidityEl) {
        currentHumidityEl.textContent = latest.humidity.toFixed(1);
    }
    
    // Temperature status message
    const statusMessageEl = document.getElementById('statusMessage');
    if (statusMessageEl) {
        const tempStatusText = latest.temp_status === 'normal' ? 'Normal' : 
                               latest.temp_status === 'warning' ? 'Peringatan' : 
                               'Bahaya!';
        statusMessageEl.textContent = `Suhu: ${tempStatusText}`;
        statusMessageEl.className = `reading-status status-${latest.temp_status}`;
    }

    const humidityStatusEl = document.getElementById('humidityStatusMessage');
    if (humidityStatusEl) {
        const humStatusText = latest.humidity_status === 'normal' ? 'Normal' : 
                              latest.humidity_status === 'warning' ? 'Peringatan' : 
                              'Bahaya!';
        humidityStatusEl.textContent = `Kelembaban: ${humStatusText}`;
        humidityStatusEl.className = `reading-status status-${latest.humidity_status}`;
    }
    
    // Update time
    const updateTimeEl = document.getElementById('updateTime');
    if (updateTimeEl) {
        updateTimeEl.textContent = `Update: ${new Date().toLocaleTimeString('id-ID')}`;
    }
}

function updateStatistics(recentData) {
    const temps = recentData.map(d => d.temperature);
    const humidities = recentData.map(d => d.humidity);
    
    // Temperature statistics
    const tempAvg = temps.reduce((a, b) => a + b, 0) / temps.length;
    const tempMax = Math.max(...temps);
    const tempMin = Math.min(...temps);
    
    // Humidity statistics
    const humAvg = humidities.reduce((a, b) => a + b, 0) / humidities.length;
    const humMax = Math.max(...humidities);
    const humMin = Math.min(...humidities);
    
    // Temperature Average
    const avgEl = document.getElementById('avgValue');
    if (avgEl) avgEl.textContent = tempAvg.toFixed(1);
    
    // Temperature Max
    const maxEl = document.getElementById('maxValue');
    if (maxEl) maxEl.textContent = tempMax.toFixed(1);
    
    // Temperature Min
    const minEl = document.getElementById('minValue');
    if (minEl) minEl.textContent = tempMin.toFixed(1);
}

function updateStatusIndicator(latest) {
    const statusDot = document.getElementById('statusDot');
    const statusText = document.getElementById('statusText');

    // Untuk DHT22: gabungkan temp_status & humidity_status
    const tempState = latest.temp_status || 'normal';
    const humState = latest.humidity_status || 'normal';
    let systemState = 'normal';
    if (tempState === 'danger' || humState === 'danger') systemState = 'danger';
    else if (tempState === 'warning' || humState === 'warning') systemState = 'warning';

    if (statusDot) {
        statusDot.className = `status-dot ${systemState}`;
    }

    if (statusText) {
        statusText.textContent = systemState === 'normal' ? 'NORMAL' :
                                systemState === 'warning' ? 'WASPADA' : 'BAHAYA';
    }

    // Update threshold displays (DHT22 pakai temperature/humidity, bukan ppm)
    const warningThresholdEl = document.getElementById('warningThreshold');
    const dangerThresholdEl = document.getElementById('dangerThreshold');

    if (warningThresholdEl) {
        warningThresholdEl.textContent = `${state.thresholds.temperature.warning_low}-${state.thresholds.temperature.warning_high} °C`;
    }

    if (dangerThresholdEl) {
        dangerThresholdEl.textContent = `${state.thresholds.temperature.danger_low}-${state.thresholds.temperature.danger_high} °C`;
    }
}

